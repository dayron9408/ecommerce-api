# =============================================================================
# Django E-Commerce API — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores segun tu entorno.
#
#   cp .env.example .env
#
# Todas las variables tienen valores por defecto sensibles para desarrollo.
# En produccion, NO uses los defaults de SECRET_KEY ni de la base de datos.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Base de Datos (PostgreSQL)
# ---------------------------------------------------------------------------
DB_NAME=ecommerce_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# Cache (Redis — opcional en desarrollo)
# ---------------------------------------------------------------------------
# Si no se configura, Django usa LocMemCache (solo para un worker).
# En produccion con multiples workers, Redis es OBLIGATORIO.
# REDIS_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Seguridad — Produccion (opcional en desarrollo)
# ---------------------------------------------------------------------------
# Las siguientes variables son opcionales. Por defecto estan en modo seguro
# para desarrollo local (HTTP, sin HSTS, etc.).
#
# En produccion, configura TODAS:
#   SECURE_SSL_REDIRECT=True
#   SESSION_COOKIE_SECURE=True
#   CSRF_COOKIE_SECURE=True
#   SECURE_HSTS_SECONDS=31536000
#   SECURE_HSTS_INCLUDE_SUBDOMAINS=True
#   SECURE_HSTS_PRELOAD=True
#   SECURE_BROWSER_XSS_FILTER=True
#   SECURE_CONTENT_TYPE_NOSNIFF=True
#
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False
# SECURE_BROWSER_XSS_FILTER=False
# SECURE_CONTENT_TYPE_NOSNIFF=True
# CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
